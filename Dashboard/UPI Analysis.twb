      <aliases enabled='yes' />
      <column aggregation='None' datatype='integer' name='[Amount (Inr) (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='3' formula='[amount_(inr)]' peg='0' size='2000' />
      </column>
      <column caption='Fraud Rate ' datatype='real' name='[Calculation_1040894524898795520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fraud_flag]) / COUNT([transaction_id])' />
      </column>
      <column caption='Total Amount' datatype='real' name='[Calculation_1040894524899033089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount_(inr)])' />
      </column>
      <column caption='Success Rate' datatype='real' name='[Calculation_1040894524899274754]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [transaction_status] = &apos;SUCCESS&apos; THEN 1 END)&#13;&#10;/ COUNT([transaction_id])' />
      </column>
      <column caption='High Value Flag' datatype='string' name='[Calculation_1040894524899524611]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [amount_(inr)] &gt; 10000 THEN &quot;High Value&quot; ELSE &quot;Normal&quot; END' />
      </column>
      <column caption='Time Category' datatype='string' name='[Calculation_1040894524899758084]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [hour_of_day] &lt;= 4 THEN &quot;Late Night&quot;&#13;&#10;ELSEIF [hour_of_day] &lt;= 12 THEN &quot;Morning&quot;&#13;&#10;ELSEIF [hour_of_day] &lt;= 18 THEN &quot;Afternoon&quot;&#13;&#10;ELSE &quot;Evening&quot;&#13;&#10;END' />
      </column>
